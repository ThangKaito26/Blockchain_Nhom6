<%- include('partials/header') %>

<div class="login-container" style="display: flex; justify-content: center; align-items: center; min-height: 80vh;">
    <div class="login-card glass-panel" style="width: 100%; max-width: 800px; display: flex; overflow: hidden; padding: 0;">
        
        <!-- Left Side: User Login -->
        <div style="flex: 1; padding: 3rem; background: rgba(255,255,255,0.02); text-align: center; border-right: 1px solid var(--glass-border);">
            <h2 class="login-title mb-20">Sinh Viên / Người Dùng</h2>
            <p class="text-muted mb-20">Đăng nhập để xem và quản lý ví chứng chỉ điện tử của riêng bạn.</p>
            <br>
            <a href="/auth/google" class="btn-google">
                <svg viewBox="0 0 48 48" width="24px" height="24px" style="margin-right: 10px;">
                    <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
                    <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
                    <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
                    <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
                </svg>
                Đăng nhập với Google
            </a>
        </div>

        <!-- Right Side: Admin Login -->
        <div style="flex: 1; padding: 3rem; background: rgba(0,0,0,0.2);">
            <h2 class="login-title mb-20 text-center">Quản Trị Viên</h2>
            <% if (typeof error !== 'undefined') { %>
                <div class="alert alert-danger" style="margin-bottom: 1rem; color: var(--danger);"><%= error %></div>
            <% } %>
            
            <form action="/login-admin" method="POST">
                <div class="form-group mb-20 text-left">
                    <label style="display:block; margin-bottom:5px;">Tài Khoản</label>
                    <input type="text" name="username" class="form-control" required>
                </div>
                <div class="form-group mb-20 text-left">
                    <label style="display:block; margin-bottom:5px;">Mật Khẩu</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
                <button type="submit" class="btn-primary w-100">Đăng Nhập</button>
            </form>
    
            <div class="divider" style="margin: 1.5rem 0; text-align: center; color: var(--text-muted); font-size: 0.9rem;">Hoặc</div>
            
            <button id="btnMetaMaskLogin" class="btn-metamask w-100">
                <img src="https://upload.wikimedia.org/wikipedia/commons/3/36/MetaMask_Fox.svg" alt="MetaMask" width="24">
                Đăng nhập bằng MetaMask
            </button>
        </div>
    </div>
</div>

<style>
    .btn-google {
        display: inline-flex;
        align-items: center;
        background: white;
        color: #333;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid #ddd;
    }
    .btn-google:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
</style>

<%- include('partials/footer') %>
