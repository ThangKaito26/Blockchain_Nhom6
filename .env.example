# ============================================================
# .env.example – Mẫu biến môi trường
# ============================================================
# SAO CHÉP file này thành ".env" rồi điền thông tin thật vào.
# KHÔNG commit file .env lên Git (đã có trong .gitignore)
# ============================================================

# ── Blockchain ──────────────────────────────────────────────
# Private key của ví Admin (KHÔNG có 0x prefix)
# Lấy từ MetaMask: Settings > Accounts > Export Private Key
PRIVATE_KEY=your_wallet_private_key_here

# RPC URL của mạng Sepolia (lấy từ Alchemy hoặc Infura miễn phí)
# https://dashboard.alchemy.com/ -> Create App -> View Key -> HTTPS
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key

# ── Tùy chọn: Etherscan API Key (để verify contract) ────────
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key

# ── Gas Report ──────────────────────────────────────────────
# Bật gas report khi chạy test (uncomment để dùng)
# REPORT_GAS=true
